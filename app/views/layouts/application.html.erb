<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "React on Rails Flagship Demo" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="application-name" content="React on Rails Flagship Demo">
    <meta name="description" content="OSS flagship demo for React on Rails: SSR, React 19, TypeScript, Redux Toolkit, Shakapacker + Rspack.">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Shakapacker packs. React on Rails auto-appends the per-component packs
        (generated/TasksApp) for any component rendered with react_component. %>
    <%= stylesheet_pack_tag "application" %>
    <%= javascript_pack_tag "application" %>
  </head>

  <body>
    <%= yield %>
  </body>
</html>
