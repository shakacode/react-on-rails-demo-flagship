# Procfile for development
# You can run these commands in separate shells
#
# To run multiple worktrees simultaneously, set different ports in each worktree's .env:
#   PORT=3001
#   SHAKAPACKER_DEV_SERVER_PORT=3036
#   RENDERER_PORT=3801
#   RENDERER_URL=http://localhost:3801
rails: ALLOW_DEMO_RENDERER_PASSWORD=true RENDERER_URL=${RENDERER_URL:-http://localhost:${RENDERER_PORT:-3800}} bundle exec rails s -p ${PORT:-3000}
dev-server: bin/shakapacker-dev-server
server-bundle: SERVER_BUNDLE_ONLY=true bin/shakapacker-watch --watch
rsc-bundle: RSC_BUNDLE_ONLY=true bin/shakapacker-watch --watch
node-renderer: RAILS_ENV=development ALLOW_DEMO_RENDERER_PASSWORD=true RENDERER_PORT=${RENDERER_PORT:-3800} node client/node-renderer.js
